{
  "moduleFileExtensions": ["ts", "js", "json"],
  "rootDir": "../",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "<rootDir>/tsconfig.test.json" }]
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1",
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "transformIgnorePatterns": ["/node_modules/(?!(\\.prisma|@prisma)/)"],
  "testEnvironment": "node"
}